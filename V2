-- ПЕРЕТАСКИВАНИЕ
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    mainFrame.Position = UDim2.new(
        startPos.X.Scale, startPos.X.Offset + delta.X,
        startPos.Y.Scale, startPos.Y.Offset + delta.Y
    )
    if dropdown.Visible then updateDropdownPos() end
end

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

mainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then update(input) end
end)

-- СБРОС
local function resetFarm()
    ignoredCoins  = {}
    currentTarget = nil
    isWaiting     = false
    lastStableY   = nil
    targetTimer   = 0
    isFlying      = false
end

local function onCharacterAdded(char)
    resetFarm()
    local hum = char:WaitForChild("Humanoid")
    hum.Died:Connect(resetFarm)
end

if player.Character then onCharacterAdded(player.Character) end
player.CharacterAdded:Connect(onCharacterAdded)

-- Смещение чтобы стоять ногами
local function getHipOffset(char)
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if hum and hrp then
        return hum.HipHeight + hrp.Size.Y / 2
    end
    return 2.5
end

-- Есть ли монеты в радиусе вообще
local function anyCoinsInRange()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == coinName and obj:IsA("BasePart") then
            if (root.Position - obj.Position).Magnitude <= coinRadius then
                return true
            end
        end
    end
    return false
end

-- ПОИСК МОНЕТЫ
local function getClosestCoinInRange()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end

    local closest, dist = nil, coinRadius
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == coinName and obj:IsA("BasePart") and not ignoredCoins[obj] then
            local d = (root.Position - obj.Position).Magnitude
            if d <= dist then
                dist    = d
                closest = obj
            end
        end
    end
    return closest
end

