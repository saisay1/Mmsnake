-- НOCLIP + Physics state
RunService.Stepped:Connect(function()
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if not char or not hum then return end

    if noclipEnabled or farmEnabled then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end

    if farmEnabled and isFlying then
        if hum:GetState() ~= Enum.HumanoidStateType.Physics then
            hum:ChangeState(Enum.HumanoidStateType.Physics)
        end
    else
        if hum:GetState() == Enum.HumanoidStateType.Physics then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
        end
    end
end)

-- ГЛАВНЫЙ ЦИКЛ ФАРМА + SPIN
RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    if spinEnabled and not farmEnabled then
        spinAngle = (spinAngle + 10) % 360
        root.CFrame = CFrame.new(root.Position) * CFrame.Angles(0, math.rad(spinAngle), 0)
    end

    if not farmEnabled then return end

    if currentTarget then
        if not currentTarget:IsDescendantOf(workspace)
        or (currentTarget.Position - root.Position).Magnitude > coinRadius then
            currentTarget = nil
            targetTimer   = 0
        end
    end

    if not anyCoinsInRange() then
        ignoredCoins = {}
        isFlying = false
        return
    end

    if isWaiting then
        if collectMode == "100" and currentTarget and currentTarget.Parent then
            local offset = get100Offset(char)
            root.CFrame = CFrame.new(currentTarget.Position + offset)
            root.AssemblyLinearVelocity  = Vector3.zero
            root.AssemblyAngularVelocity = Vector3.zero
        end
        return
    end

    -- Fast Auto
    if fastAutoEnabled and currentTarget then
        targetTimer = targetTimer + dt
        if targetTimer >= 2.5 then
            ignoredCoins[currentTarget] = true
            local skip = currentTarget
            task.delay(3, function() ignoredCoins[skip] = nil end)
            currentTarget = nil
            targetTimer   = 0
        end
    end

    if currentTarget then
        local dist = (currentTarget.Position - root.Position).Magnitude
        local stopDist = (collectMode == "100") and 0.5 or 2

        if dist < stopDist then
            isWaiting = true
            isFlying  = false
            targetTimer = 0

            if collectMode == "100" then
                local offset = get100Offset(char)
                root.CFrame = CFrame.new(currentTarget.Position + offset)
            end

            task.wait(0.2)
            local coinToIgnore = currentTarget
            ignoredCoins[coinToIgnore] = true
            task.delay(3, function() ignoredCoins[coinToIgnore] = nil end)
            currentTarget = nil
            isWaiting     = false
            if root then lastStableY = root.Position.Y end
            return
        end
    end

    if not currentTarget then
        targetTimer   = 0
        currentTarget = getClosestCoinInRange()
        if currentTarget then
            lastStableY = root.Position.Y
        end
    end

    if currentTarget then
        local diff = currentTarget.Position - root.Position
        if diff.Magnitude < 0.01 then return end

        isFlying = true

        local targetPos = currentTarget.Position
        local newPos

        if collectMode == "100" and mode100 ~= "torso" then
            if flightMode == "level" then
                -- УРОВЕНЬ: летим обычно но целимся в точку со смещением Y
                -- чтобы выбранная часть тела оказалась на уровне монеты
                local yOffset = getLevelOffset(char)
                local adjustedTarget = Vector3.new(targetPos.X, targetPos.Y + yOffset, targetPos.Z)
                local adjustedDiff = adjustedTarget - root.Position
                if adjustedDiff.Magnitude < 0.01 then return end
                newPos = root.Position + adjustedDiff.Unit * (speed * dt)

                if spinEnabled then
                    spinAngle = (spinAngle + 10) % 360
                    root.CFrame = CFrame.new(newPos) * CFrame.Angles(0, math.rad(spinAngle), 0)
                else
                    root.CFrame = CFrame.new(newPos)
                end
            else
                -- ПОВОРОТ: летим к монете, повернувшись выбранной частью вперёд
                newPos = root.Position + diff.Unit * (speed * dt)
                local lookDir = Vector3.new(diff.X, 0, diff.Z)
                local lookCF = if lookDir.Magnitude > 0.01
                    then CFrame.lookAt(newPos, newPos + lookDir)
                    else CFrame.new(newPos)

                local rot = if mode100 == "legs"
                    then CFrame.Angles(math.rad(90),  0, 0)
                    else CFrame.Angles(math.rad(-90), 0, 0)

                if spinEnabled then
                    spinAngle = (spinAngle + 10) % 360
                    root.CFrame = lookCF * rot * CFrame.Angles(0, math.rad(spinAngle), 0)
                else
                    root.CFrame = lookCF * rot
                end
            end
        else
            -- Торс или режим 90%: обычный полёт
            newPos = root.Position + diff.Unit * (speed * dt)
            if spinEnabled then
                spinAngle = (spinAngle + 10) % 360
                root.CFrame = CFrame.new(newPos) * CFrame.Angles(0, math.rad(spinAngle), 0)
            else
                root.CFrame = CFrame.new(newPos)
            end
        end

        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    else
        isFlying = false
    end
end)
