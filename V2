-- ЦИКЛ ФАРМА
RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not farmEnabled then return end

    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    if isWaiting then 
        if currentTarget and currentTarget.Parent then
            root.CFrame = CFrame.new(currentTarget.Position) * root.CFrame.Rotation
        end
        return 
    end

    if currentTarget then
        if not currentTarget.Parent or not currentTarget:IsDescendantOf(workspace) then
            currentTarget = nil
        else
            local distToCoin = (currentTarget.Position - root.Position).Magnitude
            if distToCoin < 2 then
                isWaiting = true
                task.wait(waitTime) -- 0.2 сек
                if currentTarget then
                    local c = currentTarget
                    ignoredCoins[c] = true
                    task.delay(3, function() ignoredCoins[c] = nil end)
                end
                currentTarget = nil
                isWaiting = false
            end
        end
    end

    if not currentTarget and not isWaiting then
        currentTarget = getClosestCoinInRange()
        
        -- РЕШЕНИЕ ПРОБЛЕМЫ С ПОЯВЛЕНИЕМ СВЕРХУ:
        -- Если это первая найденная монета после старта, делаем мгновенный ТП
        if currentTarget and not firstTargetFound then
            root.CFrame = CFrame.new(currentTarget.Position) * root.CFrame.Rotation
            firstTargetFound = true
        end
    end

    if currentTarget and not isWaiting then
        local direction = (currentTarget.Position - root.Position).Unit
        root.CFrame = CFrame.new(root.Position + (direction * (speed * dt))) * root.CFrame.Rotation
    end
end)

-- ЦИКЛ NOCLIP
RunService.Stepped:Connect(function()
    if (noclipEnabled or farmEnabled) and player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)
