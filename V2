-- ЦИКЛ ФАРМА
RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    
    if not root or not farmEnabled then return end

    -- Остановка физики
    root.AssemblyLinearVelocity = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    -- Если сейчас пауза 0.5 сек, стоим на месте и ничего не делаем
    if isWaiting then 
        if currentTarget and currentTarget.Parent then
            root.CFrame = CFrame.new(currentTarget.Position) * root.CFrame.Rotation
        end
        return 
    end

    -- Логика сбора
    if currentTarget then
        if not currentTarget.Parent or not currentTarget:IsDescendantOf(workspace) then
            currentTarget = nil
        else
            local distToCoin = (currentTarget.Position - root.Position).Magnitude
            
            -- Если долетели до монеты
            if distToCoin < 1.5 then
                isWaiting = true -- Включаем режим ожидания
                
                task.wait(0.5) -- Пауза 0.5 сек для гарантии сбора
                
                if currentTarget then
                    local coinToIgnore = currentTarget
                    ignoredCoins[coinToIgnore] = true
                    task.delay(3, function() ignoredCoins[coinToIgnore] = nil end)
                end
                
                currentTarget = nil 
                isWaiting = false -- Выключаем режим ожидания
                if root then lastStableY = root.Position.Y end
            end
        end
    end

    -- Ищем новую цель
    if not currentTarget and not isWaiting then
        currentTarget = getClosestCoinInRange()
    end

    -- Движение
    if currentTarget and not isWaiting then
        local targetPos = currentTarget.Position
        local direction = (targetPos - root.Position).Unit
        root.CFrame = CFrame.new(root.Position + (direction * (speed * dt))) * root.CFrame.Rotation
        lastStableY = root.Position.Y 
    elseif not currentTarget and lastStableY then
        -- Удержание высоты, если нет цели
        root.CFrame = CFrame.new(root.Position.X, lastStableY, root.Position.Z) * root.CFrame.Rotation
    end
end)

