-- Петля AntiAFK: фейковый прыжок каждые ~60 сек
local antiAfkTimer = 0
RunService.Heartbeat:Connect(function(dt)
    if antiAfkEnabled then
        antiAfkTimer = antiAfkTimer + dt
        if antiAfkTimer >= 60 then
            antiAfkTimer = 0
            local char = player.Character
            local hum  = char and char:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 then
                -- Имитируем нажатие прыжка через VirtualUser (без реального движения)
                local vu = game:GetService("VirtualUser")
                vu:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
                task.wait(0.1)
                vu:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            end
        end
    else
        antiAfkTimer = 0
    end
end)

-- ГЛАВНЫЙ ЦИКЛ ФАРМА (пункт 2 — прямолинейное движение как поезд)
RunService.Heartbeat:Connect(function(dt)
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")

    if not root or not farmEnabled then return end

    -- Полностью фиксируем физику
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    -- Ожидание после подбора монеты
    if isWaiting then
        if currentTarget and currentTarget.Parent then
            root.CFrame = CFrame.new(currentTarget.Position)
        end
        return
    end

    -- Проверяем, жив ли текущий таргет
    if currentTarget and not currentTarget:IsDescendantOf(workspace) then
        currentTarget = nil
    end

    -- Достигли монеты?
    if currentTarget then
        local dist = (currentTarget.Position - root.Position).Magnitude
        if dist < 1.5 then
            isWaiting = true

            task.wait(0.2)

            local coinToIgnore = currentTarget
            ignoredCoins[coinToIgnore] = true
            task.delay(3, function() ignoredCoins[coinToIgnore] = nil end)

            currentTarget = nil
            isWaiting     = false
            if root then lastStableY = root.Position.Y end
            return
        end
    end

    -- Ищем новую монету
    if not currentTarget then
        currentTarget = getClosestCoinInRange()
        if currentTarget then
            lastStableY = root.Position.Y
        end
    end

    -- Движение: строго прямо к монете, без поворотов, как поезд по рельсам
    if currentTarget then
        local targetPos = currentTarget.Position
        local newPos    = root.Position + (targetPos - root.Position).Unit * (speed * dt)

        -- CFrame без ротации — персонаж не наклоняется и не поворачивается
        root.CFrame = CFrame.new(newPos)
    else
        -- Нет цели — стоим на месте (фиксируем Y)
        if lastStableY then
            root.CFrame = CFrame.new(root.Position.X, lastStableY, root.Position.Z)
        end
    end
end)

