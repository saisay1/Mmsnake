-- Смещение Y для позиционирования при закреплении на монете
local function get100Offset(char)
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return Vector3.zero end
    local halfHRP = hrp.Size.Y / 2
    if mode100 == "legs" then
        return Vector3.new(0, hum.HipHeight + halfHRP, 0)
    elseif mode100 == "head" then
        return Vector3.new(0, -(hum.HipHeight + halfHRP * 2), 0)
    else
        return Vector3.zero
    end
end

-- Смещение Y для позиции во время полёта (режим "level")
-- Персонаж летит так, чтобы выбранная часть тела была на уровне монеты
local function getLevelOffset(char)
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hum or not hrp then return 0 end
    local halfHRP = hrp.Size.Y / 2
    if mode100 == "legs" then
        -- Ноги на уровне монеты: HRP поднят на HipHeight + halfHRP
        return hum.HipHeight + halfHRP
    elseif mode100 == "head" then
        -- Голова на уровне монеты: HRP опущен вниз (+ 0.8 чтобы голова доставала)
        return -(hum.HipHeight + halfHRP * 2) + 0.5
    else
        return 0 -- торс: центр HRP прямо в монете
    end
end

-- Есть ли монеты в радиусе
local function anyCoinsInRange()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == coinName and obj:IsA("BasePart") then
            if (root.Position - obj.Position).Magnitude <= coinRadius then
                return true
            end
        end
    end
    return false
end

-- ПОИСК МОНЕТЫ
local function getClosestCoinInRange()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closest, dist = nil, coinRadius
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj.Name == coinName and obj:IsA("BasePart") and not ignoredCoins[obj] then
            local d = (root.Position - obj.Position).Magnitude
            if d <= dist then
                dist    = d
                closest = obj
            end
        end
    end
    return closest
end

