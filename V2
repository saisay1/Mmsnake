-- ЛОГИКА ПЕРЕТАСКИВАНИЯ (Упрощенная)
local dragging, dragInput, dragStart, startPos
mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true; dragStart = input.Position; startPos = mainFrame.Position
        input.Changed:Connect(function() if input.UserInputState == Enum.UserInputState.End then dragging = false end end)
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- ФУНКЦИЯ ПОИСКА
local function getClosestCoinInRange()
    local char = player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local closest, dist = nil, coinRadius
    for _, object in pairs(workspace:GetDescendants()) do
        if object.Name == coinName and object:IsA("BasePart") and not ignoredCoins[object] then
            local distance = (root.Position - object.Position).Magnitude
            if distance <= dist then
                dist = distance
                closest = object
            end
        end
    end
    return closest
end

