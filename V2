            vu:Button2Down(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
            task.wait(0.1)
            vu:Button2Up(Vector2.new(0, 0), workspace.CurrentCamera.CFrame)
        end
    end
end)

-- ЕДИНЫЙ ЦИКЛ: нoclip + фарм в одном PreSimulation
-- Сначала отключаем коллизии, ПОТОМ двигаемся —
-- движок обрабатывает всё это до физического шага
RunService.PreSimulation:Connect(function(dt)
    local char = player.Character
    if not char then return end

    local root = char:FindFirstChild("HumanoidRootPart")

    -- НOCLIP: отключаем коллизии первым делом, до любого движения
    if noclipEnabled or farmEnabled then
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
        -- Дополнительно отключаем у самого root напрямую
        if root then
            root.CanCollide = false
        end
    end

    if not root or not farmEnabled then return end

    -- Полностью глушим физику
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    -- Сброс таргета если удалён или вне радиуса
    if currentTarget then
        if not currentTarget:IsDescendantOf(workspace)
        or (currentTarget.Position - root.Position).Magnitude > coinRadius then
            currentTarget = nil
        end
    end

    if isWaiting then return end

    -- Достигли монеты?
    if currentTarget then
        local dist = (currentTarget.Position - root.Position).Magnitude
        if dist < 2 then
            isWaiting = true
            task.wait(0.2)
            local coinToIgnore = currentTarget
            ignoredCoins[coinToIgnore] = true
            task.delay(3, function() ignoredCoins[coinToIgnore] = nil end)
            currentTarget = nil
            isWaiting     = false
            if root then lastStableY = root.Position.Y end
            return
        end
    end

    -- Ищем новую монету
    if not currentTarget then
        currentTarget = getClosestCoinInRange()
        if currentTarget then
            lastStableY = root.Position.Y
        end
    end

    if currentTarget then
        local diff = currentTarget.Position - root.Position
        if diff.Magnitude < 0.01 then return end

        local newPos = root.Position + diff.Unit * (speed * dt)
        root.CFrame = CFrame.new(newPos)

        -- Обнуляем скорость после CFrame — движку нечего применять
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero

    elseif lastStableY then
        root.CFrame = CFrame.new(root.Position.X, lastStableY, root.Position.Z)
        root.AssemblyLinearVelocity  = Vector3.zero
        root.AssemblyAngularVelocity = Vector3.zero
    end
end)
