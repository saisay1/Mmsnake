-- Логика переключения разделов
local function switchSection(button, sectionName, displayName)
	-- Сброс цветов всех кнопок
	PlayerButton.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
	PlayerButton.TextColor3 = Color3.fromRGB(100, 100, 100)
	MainButton.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
	MainButton.TextColor3 = Color3.fromRGB(100, 100, 100)
	ViborButton.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
	ViborButton.TextColor3 = Color3.fromRGB(100, 100, 100)
	
	-- Подсветка активной кнопки
	button.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
	button.TextColor3 = Color3.fromRGB(255, 255, 255)
	
	-- Смена заголовка
	ContentTitle.Text = displayName
end

-- Подключение кнопок разделов
PlayerButton.MouseButton1Click:Connect(function()
	switchSection(PlayerButton, "Player", "PLAYER")
end)

MainButton.MouseButton1Click:Connect(function()
	switchSection(MainButton, "Main", "MAIN")
end)

ViborButton.MouseButton1Click:Connect(function()
	switchSection(ViborButton, "Vibor", "VIBOR")
end)

-- Кнопка скрытия (верхняя белая)
local isMinimized = false
MinimizeButton.MouseButton1Click:Connect(function()
	isMinimized = not isMinimized
	if isMinimized then
		MainFrame:TweenSize(UDim2.new(0, 450, 0, 45), "Out", "Quad", 0.3, true)
	else
		MainFrame:TweenSize(UDim2.new(0, 450, 0, 320), "Out", "Quad", 0.3, true)
	end
end)

-- Кнопка закрытия (нижняя ярко-зелёная)
CloseButton.MouseButton1Click:Connect(function()
	ScreenGui:Destroy()
end)

-- Установка начального раздела
switchSection(PlayerButton, "Player", "PLAYER")

