--[[
    COIN Collector для Xeno
    Включение/выключение: нажмите "U" (или другую клавишу)
    При активации: летит к ближайшей монете Coin_Server со скоростью 1.5
--]]

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- ========== НАСТРОЙКИ ==========
local SPEED = 1.5                    -- Скорость полёта
local TOGGLE_KEY = Enum.KeyCode.U    -- Клавиша для вкл/выкл
local NOTIFY = true                  -- Показывать уведомления

-- ========== ПЕРЕМЕННЫЕ ==========
local isActive = false
local currentTarget = nil
local connection = nil

-- ========== УВЕДОМЛЕНИЕ ==========
local function notify(text, isError)
    if not NOTIFY then return end
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "COIN Collector",
        Text = text,
        Duration = 2,
        Icon = isError and "rbxassetid://238405577" or "rbxassetid://239867487"
    })
end

-- ========== ПОИСК БЛИЖАЙШЕЙ МОНЕТЫ ==========
local function findNearestCoin()
    local character = LocalPlayer.Character
    if not character then return nil end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local currentPos = rootPart.Position
    local nearestCoin = nil
    local nearestDist = math.huge
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Coin_Server" and obj:IsA("BasePart") and obj.Parent then
            local dist = (currentPos - obj.Position).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearestCoin = obj
            end
        end
    end
    
    return nearestCoin, nearestDist
end

-- ========== ВКЛЮЧЕНИЕ ПОЛЁТА ==========
local function enableFly()
    if connection then
        connection:Disconnect()
        connection = nil
    end
    
    isActive = true
    
    connection = RunService.Heartbeat:Connect(function()
        if not isActive then return end
        
        local character = LocalPlayer.Character
        if not character then return end
        
        local humanoid = character:FindFirstChild("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        
        if not humanoid or not rootPart then return end
        
        -- Проверка на жизнь
        if humanoid.Health <= 0 then
            disableFly()
            notify("Персонаж мёртв, COIN выключен", true)
            return
        end
        
        -- Поиск ближайшей монеты
        local targetCoin, distance = findNearestCoin()
        
        if targetCoin and targetCoin.Parent then
            currentTarget = targetCoin
            
            -- Направление к монете
            local direction = (targetCoin.Position - rootPart.Position).Unit
            rootPart.Velocity = direction * SPEED
            
            -- Отключаем гравитацию
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            
            -- Если подобрал монету (очень близко)
            if distance < 3 then
                -- Небольшая задержка, чтобы монета успела исчезнуть
                task.wait(0.05)
                currentTarget = nil
            end
        else
            -- Нет монет на карте
            rootPart.Velocity = Vector3.zero
        end
    end)
    
    notify("COIN включён, лечу к монетам!")
    print("[COIN] Включён")
end

-- ========== ВЫКЛЮЧЕНИЕ ПОЛЁТА ==========
local function disableFly()
    isActive = false
    currentTarget = nil
    
    if connection then
        connection:Disconnect()
        connection = nil
    end
    
    -- Восстанавливаем гравитацию
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        end
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            rootPart.Velocity = Vector3.zero
        end
    end
    
    notify("COIN выключен")
    print("[COIN] Выключен")
end

-- ========== ПЕРЕКЛЮЧЕНИЕ ==========
local function toggleCoin()
    if isActive then
        disableFly()
    else
        enableFly()
    end
end

-- ========== СОЗДАНИЕ GUI КНОПКИ (простая) ==========
local function createSimpleButton()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "CoinCollector"
    screenGui.Parent = game:GetService("CoreGui")
    screenGui.ResetOnSpawn = false
    
    local button = Instance.new("TextButton")
    button.Name = "CoinButton"
    button.Parent = screenGui
    button.Size = UDim2.new(0, 60, 0, 60)
    button.Position = UDim2.new(0, 10, 0.5, -30)
    button.BackgroundColor3 = Color3.fromRGB(80, 100, 200)
    button.Text = "₿"
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.TextSize = 28
    button.Font = Enum.Font.GothamBold
    button.BorderSizePixel = 0
    button.Draggable = true
    button.Active = true
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = button
    
    -- Обновление цвета кнопки при переключении
    local updateButtonColor = function()
        if isActive then
            button.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        else
            button.BackgroundColor3 = Color3.fromRGB(80, 100, 200)
        end
    end
    
    button.MouseButton1Click:Connect(function()
        toggleCoin()
        updateButtonColor()
    end)
    
    updateButtonColor()
    return button
end

-- ========== ЗАПУСК ==========
createSimpleButton()

-- Горячая клавиша U
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == TOGGLE_KEY then
        toggleCoin()
        -- Обновляем цвет кнопки (находим её)
        local gui = game:GetService("CoreGui"):FindFirstChild("CoinCollector")
        if gui then
            local btn = gui:FindFirstChild("CoinButton")
            if btn then
                if isActive then
                    btn.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
                else
                    btn.BackgroundColor3 = Color3.fromRGB(80, 100, 200)
                end
            end
        end
    end
end)

print("[COIN Collector] Загружен!")
print("[COIN Collector] Кнопка ₿ слева по середине")
print("[COIN Collector] Клавиша U для вкл/выкл")
