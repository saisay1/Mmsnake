-- ========== ФУНКЦИЯ ПОИСКА БЛИЖАЙШЕЙ МОНЕТЫ ==========
local function findNearestCoin()
    local character = LocalPlayer.Character
    if not character then return nil end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    if not rootPart then return nil end
    
    local currentPos = rootPart.Position
    local nearestCoin = nil
    local nearestDist = math.huge
    
    -- Поиск всех объектов с именем Coin_Server
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj.Name == "Coin_Server" and obj:IsA("BasePart") then
            local coinPos = obj.Position
            local dist = (currentPos - coinPos).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearestCoin = obj
            end
        end
    end
    
    return nearestCoin, nearestDist
end

-- ========== ФУНКЦИЯ ПОЛЁТА К МОНЕТЕ ==========
local function flyToCoin(coin)
    if not coin or not coin.Parent then return false end
    
    local character = LocalPlayer.Character
    if not character then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
    
    if not humanoid or not rootPart then return false end
    
    -- Отключаем гравитацию
    humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
    humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
    humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    
    local direction = (coin.Position - rootPart.Position).Unit
    local velocity = direction * COIN_SPEED
    
    -- Устанавливаем скорость
    rootPart.Velocity = velocity
    
    return true
end

-- ========== ОСНОВНОЙ ЦИКЛ COIN ==========
local function startCoinFly()
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    flyConnection = RunService.Heartbeat:Connect(function()
        if not coinActive then return end
        
        local character = LocalPlayer.Character
        if not character then return end
        
        local humanoid = character:FindFirstChild("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
        
        if not humanoid or not rootPart then return end
        
        -- Проверяем, живой ли игрок
        if humanoid.Health <= 0 then
            coinActive = false
            return
        end
        
        -- Ищем ближайшую монету
        local nearestCoin, distance = findNearestCoin()
        
        if nearestCoin and nearestCoin.Parent then
            currentTargetCoin = nearestCoin
            
            -- Летим к монете
            local direction = (nearestCoin.Position - rootPart.Position).Unit
            rootPart.Velocity = direction * COIN_SPEED
            
            -- Если очень близко к монете (подобрал)
            if distance < 3 then
                -- Ждём следующего кадра, чтобы монета исчезла и выбралась новая
                task.wait(0.05)
                currentTargetCoin = nil
            end
        else
            -- Нет монет на карте, останавливаемся
            rootPart.Velocity = Vector3.zero
        end
    end)
end

local function stopCoinFly()
    coinActive = false
    currentTargetCoin = nil
    
    if flyConnection then
        flyConnection:Disconnect()
        flyConnection = nil
    end
    
    -- Восстанавливаем гравитацию
    local character = LocalPlayer.Character
    if character then
        local humanoid = character:FindFirstChild("Humanoid")
        if humanoid then
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
        end
        local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso")
        if rootPart then
            rootPart.Velocity = Vector3.zero
        end
    end
end

