-- ========== ПЕРЕКЛЮЧЕНИЕ РАЗДЕЛОВ ==========
local function switchSection(sectionName)
    btnP.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
    btnM.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
    btnV.BackgroundColor3 = Color3.fromRGB(100, 100, 120)
    btnP.TextColor3 = Color3.fromRGB(200, 200, 200)
    btnM.TextColor3 = Color3.fromRGB(200, 200, 200)
    btnV.TextColor3 = Color3.fromRGB(200, 200, 200)
    
    if sectionName == "Player" then
        btnP.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        btnP.TextColor3 = Color3.fromRGB(255, 255, 255)
        sectionTitle.Text = "PLAYER"
    elseif sectionName == "Main" then
        btnM.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        btnM.TextColor3 = Color3.fromRGB(255, 255, 255)
        sectionTitle.Text = "MAIN"
    elseif sectionName == "Vibor" then
        btnV.BackgroundColor3 = Color3.fromRGB(80, 200, 80)
        btnV.TextColor3 = Color3.fromRGB(255, 255, 255)
        sectionTitle.Text = "VIBOR"
    end
    
    for _, child in ipairs(scrollFrame:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    local targetSection = sections[sectionName]
    if targetSection then
        for _, item in ipairs(targetSection) do
            item.toggle.Parent = scrollFrame
        end
    end
end

btnP.MouseButton1Click:Connect(function() switchSection("Player") end)
btnM.MouseButton1Click:Connect(function() switchSection("Main") end)
btnV.MouseButton1Click:Connect(function() switchSection("Vibor") end)

