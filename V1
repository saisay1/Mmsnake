local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Настройки
_G.CoinFarmEnabled = true -- Переключатель (Toggle)
local speed = 1.5 -- Твоя скорость
local coinName = "Coin_Server"

-- Функция поиска ближайшей монеты
local function getClosestCoin()
    local closestCoin = nil
    local shortestDistance = math.huge

    for _, object in pairs(workspace:GetDescendants()) do
        if object.Name == coinName and object:IsA("BasePart") then
            local distance = (rootPart.Position - object.Position).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                closestCoin = object
            end
        end
    end
    return closestCoin
end

local currentTarget = nil

-- Основной цикл полета
RunService.Heartbeat:Connect(function()
    if not _G.CoinFarmEnabled then 
        currentTarget = nil
        return 
    end

    -- Если текущаяя цель исчезла или ее нет, ищем новую
    if not currentTarget or not currentTarget.Parent then
        currentTarget = getClosestCoin()
    end

    if currentTarget then
        -- Вычисляем направление к монете
        local direction = (currentTarget.Position - rootPart.Position).Unit
        
        -- Двигаем персонажа прямолинейно
        -- Используем CFrame для плавного перемещения без физических рывков
        rootPart.CFrame = rootPart.CFrame + (direction * speed)
        
        -- Опционально: заставляем персонажа смотреть на монету
        rootPart.CFrame = CFrame.lookAt(rootPart.Position, currentTarget.Position)
    end
end)
